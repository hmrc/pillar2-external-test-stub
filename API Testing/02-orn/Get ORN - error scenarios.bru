meta {
  name: Get ORN - error scenarios
  type: http
  seq: 4
}

# @name missing-pillar2-id
get {
  url: {{baseUrl}}/RESTAdapter/PLR/overseas-return-notification?accountingPeriodFrom=2024-01-01&accountingPeriodTo=2024-12-31
}

headers {
  Content-Type: application/json
  Authorization: validBearerToken
}

tests {
  test("Status code is 422") {
    expect(response.status).toBe(422)
  }

  test("Error response has correct structure") {
    expect(response.body.errors.code).toBe("002")
    expect(response.body.errors.text).toBe("Pillar2 ID is missing")
  }
}

# @name invalid-dates
get {
  url: {{baseUrl}}/RESTAdapter/PLR/overseas-return-notification?accountingPeriodFrom=invalid-date&accountingPeriodTo=2024-12-31
  headers: {
    Content-Type: application/json
    Authorization: Bearer token
    X-Pillar2-Id: XMPLR0123456789
  }
}

tests {
  test("Status code is 422") {
    expect(response.status).toBe(422)
  }

  test("Error response has correct structure") {
    expect(response.body.errors.code).toBe("003")
    expect(response.body.errors.text).toBe("Request could not be processed")
  }
}

# @name non-existent-submission
get {
  url: {{baseUrl}}/RESTAdapter/PLR/overseas-return-notification?accountingPeriodFrom=2025-01-01&accountingPeriodTo=2025-12-31
  headers: {
    Content-Type: application/json
    Authorization: Bearer token
    X-Pillar2-Id: XMPLR0123456789
  }
}

tests {
  test("Status code is 404") {
    expect(response.status).toBe(404)
  }

  test("Error response has correct structure") {
    expect(response.body.errors.code).toBe("404")
    expect(response.body.errors.text).toBe("No ORN submission found")
  }
}

# @name server-error
get {
  url: {{baseUrl}}/RESTAdapter/PLR/overseas-return-notification?accountingPeriodFrom=2024-01-01&accountingPeriodTo=2024-12-31
  headers: {
    Content-Type: application/json
    Authorization: Bearer token
    X-Pillar2-Id: XMPLR9999999999
  }
}

tests {
  test("Status code is 500") {
    expect(response.status).toBe(500)
  }

  test("Error response has correct structure") {
    expect(response.body.errors.code).toBe("500")
    expect(response.body.errors.text).toBe("Internal server error")
  }
} 