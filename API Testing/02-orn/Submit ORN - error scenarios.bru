meta {
  name: Submit ORN - error scenarios
  type: http
  seq: 3
}

# Test missing Pillar2 ID
post {
  name: Missing Pillar2 ID
  url: {{baseUrl}}/RESTAdapter/PLR/overseas-return-notification
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: validBearerToken
}

body:json {
  {
    "accountingPeriodFrom": "2024-01-01",
    "accountingPeriodTo": "2024-12-31",
    "filedDateGIR": "2025-01-10",
    "countryGIR": "US",
    "reportingEntityName": "Newco PLC",
    "TIN": "US12345678",
    "issuingCountryTIN": "US"
  }
}

tests {
  test("Response contains correct error code", function() {
    expect(res.body.errors.code).to.equal("002");
  });
  
  test("Response contains correct status code", function() {
    expect(res.status).to.equal(422);
  });
}

# Test invalid JSON payload
post {
  name: Invalid JSON payload
  url: {{baseUrl}}/RESTAdapter/PLR/overseas-return-notification
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-Pillar2-Id: {{nonDomesticPlrId}}
  Authorization: validBearerToken
}

body:json {
  {
    "accountingPeriodFrom": "invalid-date",
    "accountingPeriodTo": "2024-12-31",
    "invalidField": true
  }
}

tests {
  test("Response contains correct error code", function() {
    expect(res.body.errors.code).to.equal("400");
  });
  
  test("Response contains correct status code", function() {
    expect(res.status).to.equal(400);
  });
}

# Test non-existent organisation
post {
  name: Non-existent organisation
  url: {{baseUrl}}/RESTAdapter/PLR/overseas-return-notification
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-Pillar2-Id: XEPLR0000000000
  Authorization: validBearerToken
}

body:json {
  {
    "accountingPeriodFrom": "2024-01-01",
    "accountingPeriodTo": "2024-12-31",
    "obligationMTT": false,
    "electionUKGAAP": true,
    "overseasEntityDetails": {
      "countryCode": "FR",
      "entityName": "French Subsidiary Ltd",
      "registrationNumber": "FR123456789"
    },
    "liabilities": {
      "totalLiability": 15000.99,
      "totalLiabilityDTT": 7500.99,
      "totalLiabilityIIR": 5000.00,
      "totalLiabilityUTPR": 2500.00
    }
  }
}

tests {
  test("Response contains correct error code", function() {
    expect(res.body.errors.code).to.equal("007");
  });
  
  test("Response contains correct status code", function() {
    expect(res.status).to.equal(422);
  });
} 